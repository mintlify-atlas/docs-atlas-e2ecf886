  "keyFeatures": [
    "Command validation and risk analysis",
    "Intelligent sandbox execution with caching",
    "CVE scanning for vulnerable dependencies",
    "Session tracking and audit trails",
    "Secret and security code scanning",
    "Trust store for approved commands",
    "AI agent integration (Cursor, VSCode, OpenClaw)",
    "Multiple enforcement modes"
  ],
  "publicApiSurface": [
    "exec - Protected command execution",
    "validate - Script validation without execution",
    "session - Session management (start, show, list, end)",
    "audit - Audit reports (session, repo, npm, python)",
    "cve - CVE scanning (sync, scan, explain)",
    "scan-secrets - Secret detection in code",
    "scan-security - Security code pattern detection",
    "trust - Trust store management (add, list, remove, clean)",
    "context - Context summaries for AI agents",
    "roadmap - Roadmap planning for projects",
    "metrics - Sandbox usage metrics",
    "init - Initialize configuration",
    "explain - Explain security risks",
    "lockdown - Strict enforcement mode",
    "prompt-firewall - Prompt injection detection",
    "validate-agent - Agent-specific validation",
    "seed - Seed agent instructions",
    "serve - Web UI server"
  ]
}
